# Copy to `.env` (`cp .env.example .env`) and fill in the values.

# ── Database ─────────────────────────────────────────────────────────────────
# Any managed PostgreSQL works (Neon, Supabase, Vercel Postgres, RDS, …).
# Neon (free serverless tier) is recommended — https://neon.tech
# Use `?sslmode=verify-full` for managed providers (they present trusted certs).
DATABASE_URL="postgresql://user:password@host:5432/jobboard?sslmode=verify-full"
#
# Running your own local Postgres instead? Point it at that instance and use
# `?sslmode=disable`, e.g.
#   DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/jobboard?sslmode=disable"

# ── Admin panel (/admin) ─────────────────────────────────────────────────────
# Password used to sign in at /admin/login. Change this for any real deploy.
ADMIN_PASSWORD="admin123"
# Secret used to sign admin session cookies. Generate one: `openssl rand -base64 32`
ADMIN_JWT_SECRET="change-me-to-a-long-random-string"
